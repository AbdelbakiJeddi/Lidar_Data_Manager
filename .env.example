# MinIO Configuration
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=False
MINIO_BUCKET_RAW=lidar-raw
MINIO_BUCKET_PROCESSED=lidar-processed

# MongoDB Configuration
